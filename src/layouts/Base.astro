---
import { ClientRouter } from 'astro:transitions';
import { url } from '../utils/url';
import AmbientPlayer from '../components/global/AmbientPlayer.astro';
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Matryca — baza 33 udokumentowanych skandali Big Tech. Prywatność, bezpieczeństwo, prawa obywateli.',
  ogImage,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const pageTitle = title === 'Matryca' ? title : `${title} — Matryca`;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <title>{pageTitle}</title>

    <!-- No external font CDN — fonts loaded locally via SCSS -->

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={url('/favicon.svg')} />

    <!-- Theme: default LIGHT, dark tylko po świadomym toggle.
         (Opcja C: portal editorialny startuje jasno dla wszystkich;
          `prefers-color-scheme: dark` nie jest automatycznie honorowane.
          Parametr ?theme= zachowany dla strony porównawczej.) -->
    <script is:inline>
      (function () {
        const urlTheme = new URLSearchParams(location.search).get('theme');
        const stored = localStorage.getItem('matryca-theme');
        document.documentElement.setAttribute(
          'data-theme',
          urlTheme || stored || 'light'
        );
      })();
    </script>

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Astro view transitions: subtle crossfade between pages -->
    <ClientRouter fallback="swap" />
  </head>
  <body>
    <slot />
    <AmbientPlayer />

    <!-- Global scroll-fade observer: any element with class="reveal-on-scroll"
         gets .is-revealed when it enters the viewport. -->
    <script is:inline>
      (function () {
        function arm() {
          const els = document.querySelectorAll('.reveal-on-scroll:not(.is-revealed)');
          if (!('IntersectionObserver' in window)) {
            els.forEach((el) => el.classList.add('is-revealed'));
            return;
          }
          const io = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add('is-revealed');
                  io.unobserve(entry.target);
                }
              });
            },
            { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
          );
          els.forEach((el) => io.observe(el));
        }
        arm();
        // Re-arm after Astro view-transition swaps the DOM
        document.addEventListener('astro:page-load', arm);
      })();
    </script>
  </body>
</html>

<style lang="scss" is:global>
  @use '../styles/global.scss';
</style>
