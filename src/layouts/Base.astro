---
import { ClientRouter } from 'astro:transitions';
import { url } from '../utils/url';
import AmbientPlayer from '../components/global/AmbientPlayer.astro';
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Matryca — baza 33 udokumentowanych skandali Big Tech. Prywatność, bezpieczeństwo, prawa obywateli.',
  ogImage,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const pageTitle = title === 'Matryca' ? title : `${title} — Matryca`;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <title>{pageTitle}</title>

    <!-- No external font CDN — fonts loaded locally via SCSS -->

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={url('/favicon.svg')} />

    <!-- Theme: default LIGHT, dark tylko po świadomym toggle.
         (Opcja C: portal editorialny startuje jasno dla wszystkich;
          `prefers-color-scheme: dark` nie jest automatycznie honorowane.
          Parametr ?theme= zachowany dla strony porównawczej.)

         Pre-paint theme application — runs before <body> renders to avoid flash.
         Also re-applies on Astro view-transition swaps. -->
    <script is:inline>
      (function () {
        function applyTheme() {
          const urlTheme = new URLSearchParams(location.search).get('theme');
          const stored = localStorage.getItem('matryca-theme');
          document.documentElement.setAttribute(
            'data-theme',
            urlTheme || stored || 'light'
          );
        }
        applyTheme();
        // ClientRouter replaces <html data-theme> on swap; re-apply right before
        document.addEventListener('astro:before-swap', (e) => {
          /** @type {HTMLElement} */
          const newDoc = e.newDocument.documentElement;
          const stored = localStorage.getItem('matryca-theme') || 'light';
          newDoc.setAttribute('data-theme', stored);
        });
      })();
    </script>

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Astro view transitions: subtle crossfade between pages -->
    <ClientRouter fallback="swap" />
  </head>
  <body>
    <slot />
    <AmbientPlayer />

    <!-- Global scroll-fade observer + theme toggle wiring.
         Both run on initial load AND re-bind after every Astro view-transition
         swap, since <script type="module"> in components only runs once. -->
    <script is:inline>
      (function () {
        function armScrollReveal() {
          const els = document.querySelectorAll('.reveal-on-scroll:not(.is-revealed)');
          if (!('IntersectionObserver' in window)) {
            els.forEach((el) => el.classList.add('is-revealed'));
            return;
          }
          const io = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add('is-revealed');
                  io.unobserve(entry.target);
                }
              });
            },
            { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
          );
          els.forEach((el) => io.observe(el));
        }

        function bindThemeToggle() {
          const toggle = document.getElementById('theme-toggle');
          const icon = document.getElementById('theme-icon');
          if (!toggle) return;

          // Always sync the icon to the current theme — even if listener was
          // already bound, re-running this is harmless and keeps the icon right.
          function syncIcon() {
            if (!icon) return;
            const t = document.documentElement.getAttribute('data-theme');
            icon.textContent = t === 'dark' ? '☽' : '☀';
          }
          syncIcon();

          // Idempotent: skip if we already bound this exact element instance
          if (toggle.dataset.themeBound === '1') return;
          toggle.dataset.themeBound = '1';

          toggle.addEventListener('click', () => {
            const cur = document.documentElement.getAttribute('data-theme');
            const next = cur === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            localStorage.setItem('matryca-theme', next);
            syncIcon();
          });
        }

        function init() {
          armScrollReveal();
          bindThemeToggle();
        }

        // Initial load
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init);
        } else {
          init();
        }
        // Every view-transition page swap
        document.addEventListener('astro:page-load', init);
      })();
    </script>
  </body>
</html>

<style lang="scss" is:global>
  @use '../styles/global.scss';
</style>
