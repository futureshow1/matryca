---
import { url } from '../utils/url';
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Matryca — baza 33 udokumentowanych skandali Big Tech. Prywatność, bezpieczeństwo, prawa obywateli.',
  ogImage,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const pageTitle = title === 'Matryca' ? title : `${title} — Matryca`;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <title>{pageTitle}</title>

    <!-- No external font CDN — fonts loaded locally via SCSS -->

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={url('/favicon.svg')} />

    <!-- Theme: default LIGHT, dark tylko po świadomym toggle.
         (Opcja C: portal editorialny startuje jasno dla wszystkich;
          `prefers-color-scheme: dark` nie jest automatycznie honorowane.
          Parametr ?theme= zachowany dla strony porównawczej.) -->
    <script is:inline>
      (function () {
        const urlTheme = new URLSearchParams(location.search).get('theme');
        const stored = localStorage.getItem('matryca-theme');
        document.documentElement.setAttribute(
          'data-theme',
          urlTheme || stored || 'light'
        );
      })();
    </script>

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    {ogImage && <meta property="og:image" content={ogImage} />}
  </head>
  <body>
    <slot />
  </body>
</html>

<style lang="scss" is:global>
  @use '../styles/global.scss';
</style>
