---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__privacy">
      <span class="footer__privacy-label">Prywatność:</span>
      <span>Portal nie zbiera danych o użytkownikach. Bez cookies. Bez analytics. Bez trackerów.</span>
    </div>

    <nav class="footer__nav" aria-label="Nawigacja pomocnicza">
      <a href="/sprawy/">Sprawy</a>
      <a href="/sygnalisci/">Kto odkrył?</a>
      <a href="/firmy/">Firmy</a>
      <a href="/tagi/">Tagi</a>
      <a href="/teksty/">Teksty</a>
      <a href="/o-projekcie/">O projekcie</a>
      <a href="/metodologia/">Metodologia</a>
    </nav>

    <p class="footer__copy">
      <span class="meta">Matryca &copy; {year} — materiał edukacyjny do swobodnego wykorzystania.</span>
    </p>
  </div>
</footer>

<style lang="scss">
  .footer {
    border-top: 0.5px solid var(--border);
    margin-top: var(--space-24);
    padding-block: var(--space-8);
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .footer__privacy {
    font-size: var(--text-small);
    color: var(--text-secondary);

    .footer__privacy-label {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--accent);
      margin-right: var(--gap-2);
    }
  }

  .footer__nav {
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;

    a {
      font-size: var(--text-small);
      color: var(--text-secondary);
      text-decoration: none;
      transition: color var(--transition-fast);

      &:hover {
        color: var(--accent);
      }
    }
  }

  .footer__copy {
    color: var(--text-tertiary);
  }
</style>
