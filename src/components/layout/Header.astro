---
import { url } from '../../utils/url';
import { altLangUrl } from '../../utils/lang-switcher';
const navLinks = [
  { href: '/sprawy/', label: 'Sprawy' },
  { href: '/sygnalisci/', label: 'Kto odkrył?' },
  { href: '/gra/', label: 'Co byś zrobił?' },
  { href: '/kwestionariusz/', label: 'Ile wiedzą?' },
  { href: '/teksty/', label: 'Teksty' },
];

const currentPath = Astro.url.pathname;
const enHref = altLangUrl(currentPath, 'en');
---

<header class="header">
  <div class="container header__inner">
    <a href={url('/')} class="header__logo" aria-label="Matryca — strona główna">
      <span class="header__logo-bar" aria-hidden="true"></span>
      <span class="header__logo-name">Matryca</span>
      <span class="header__logo-sub">/ baza wiedzy</span>
    </a>

    <nav class="header__nav" aria-label="Nawigacja główna">
      <ul class="header__nav-list">
        {navLinks.map((link) => {
          const resolved = url(link.href);
          const isActive = currentPath === resolved || currentPath.startsWith(resolved);
          return (
            <li>
              <a
                href={resolved}
                class={`header__nav-link${isActive ? ' header__nav-link--active' : ''}`}
              >
                {link.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    <div class="header__actions">
      <a
        href={enHref}
        class="header__lang"
        title="English edition — same page"
      >EN</a>
      <button
        class="header__theme-toggle"
        id="theme-toggle"
        aria-label="Zmień motyw"
        title="Jasny / ciemny motyw"
      >
        <span class="header__theme-icon" aria-hidden="true" id="theme-icon">☀</span>
      </button>
    </div>
  </div>
</header>

<!-- Theme toggle wiring lives in Base.astro inline script so it survives
     Astro view-transitions (this <script type="module"> would only run once). -->

<style lang="scss">
  .header {
    border-bottom: 0.5px solid var(--border);
    background: var(--bg-primary);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header__inner {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    padding-block: var(--space-4);
  }

  .header__logo {
    display: flex;
    align-items: baseline;
    gap: 12px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .header__logo-bar {
    display: block;
    width: 3px;
    height: 22px;
    background: var(--accent);
    border-radius: 2px;
    flex-shrink: 0;
    position: relative;
    top: 2px;
  }

  .header__logo-name {
    font-family: var(--font-serif);
    font-size: 20px;
    font-weight: 500;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  .header__logo-sub {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-tertiary);
    letter-spacing: 0.02em;
  }

  .header__nav {
    flex: 1;
  }

  .header__nav-list {
    display: flex;
    gap: var(--space-6);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .header__nav-link {
    font-size: var(--text-small);
    color: var(--text-secondary);
    text-decoration: none;
    padding-bottom: 2px;
    border-bottom: 1px solid transparent;
    transition: color var(--transition-fast), border-color var(--transition-fast);

    &:hover {
      color: var(--text-primary);
      border-color: var(--text-primary);
    }

    &--active {
      color: var(--text-primary);
      border-color: var(--accent);
    }
  }

  .header__actions {
    display: flex;
    align-items: center;
    gap: var(--gap-3);
    flex-shrink: 0;
  }

  .header__lang {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 4px 8px;
    border: 0.5px solid var(--border);
    border-radius: var(--radius-sm);
    transition: color var(--transition-fast), border-color var(--transition-fast);

    &:hover {
      color: var(--accent);
      border-color: var(--accent);
    }
  }

  .header__theme-toggle {
    background: none;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--text-secondary);
    font-size: 13px;
    transition: border-color var(--transition-fast), color var(--transition-fast);

    &:hover {
      border-color: var(--border-hover);
      color: var(--text-primary);
    }
  }

  @media (max-width: 640px) {
    .header__nav {
      display: none;
    }
  }
</style>
