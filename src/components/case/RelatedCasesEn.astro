---
import { getCollection } from 'astro:content';
import Badge from '../ui/Badge.astro';
import { url } from '../../utils/url';

interface Props {
  ids: string[];
  currentId: string;
}

const { ids, currentId } = Astro.props;

// Prefer EN cards if they exist — fall back to PL cards
const allCasesEn = await getCollection('cases_en');
const allCasesPl = await getCollection('cases');
const enById = new Map(allCasesEn.map((c) => [c.data.id, c]));

const relatedCases = ids
  .map((id) => {
    const en = enById.get(id);
    if (en) return { ...en, hasEn: true };
    const pl = allCasesPl.find((c) => c.data.id === id);
    if (pl) return { ...pl, hasEn: false };
    return null;
  })
  .filter((c): c is NonNullable<typeof c> => Boolean(c) && c!.data.id !== currentId);
---

{relatedCases.length > 0 && (
  <section class="related" aria-labelledby="related-heading">
    <div class="related__header">
      <h2 id="related-heading" class="related__title">Related cases</h2>
      <p class="related__lede">
        Cases that share a company, mechanism, legal precedent or jurisdiction.
      </p>
    </div>

    <ul class="related__list">
      {relatedCases.map((c) => {
        const href = c.hasEn
          ? url(`/en/cases/${c.data.slug}/`)
          : url(`/sprawy/${c.data.slug}/`);
        return (
          <li class="related__item">
            <a href={href} class="related__link">
              <div class="related__head">
                <Badge group={c.data.group} size="sm" />
                <span class="related__id meta">{c.data.id}</span>
                <span class="related__year meta">{c.data.year_revealed}</span>
              </div>
              <p class="related__name">{c.data.title}</p>
              {c.data.subtitle && <p class="related__sub">{c.data.subtitle}</p>}
              <p class="related__meta meta">
                {c.data.companies.slice(0, 2).join(' · ')}
                {!c.hasEn && <span class="related__pl-flag"> · PL only</span>}
              </p>
            </a>
          </li>
        );
      })}
    </ul>
  </section>
)}

<style lang="scss">
  .related {
    margin-top: var(--space-10);
    padding-top: var(--space-8);
    border-top: 0.5px solid var(--border);
  }

  .related__header {
    margin-bottom: var(--space-6);
  }

  .related__title {
    font-family: var(--font-serif);
    font-size: 24px;
    font-weight: 500;
    margin-bottom: var(--space-2);
  }

  .related__lede {
    font-size: 14px;
    color: var(--text-secondary);
    margin: 0;
  }

  .related__list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--gap-3);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .related__item {
    margin: 0;
  }

  .related__link {
    display: flex;
    flex-direction: column;
    gap: var(--gap-2);
    padding: var(--gap-5);
    background: var(--bg-card);
    border: 0.5px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    height: 100%;
    transition: border-color var(--transition-fast);

    &:hover {
      border-color: var(--accent);

      .related__name { color: var(--accent); }
    }
  }

  .related__head {
    display: flex;
    align-items: center;
    gap: var(--gap-2);
  }

  .related__id {
    font-size: 11px;
    color: var(--text-tertiary);
    margin-right: auto;
  }

  .related__year {
    font-size: 11px;
    color: var(--text-tertiary);
  }

  .related__name {
    font-family: var(--font-serif);
    font-size: 15px;
    font-weight: 500;
    line-height: 1.3;
    margin: 0;
    color: var(--text-primary);
    transition: color var(--transition-fast);
  }

  .related__sub {
    font-size: 12px;
    line-height: 1.45;
    color: var(--text-secondary);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .related__meta {
    font-size: 11px;
    color: var(--text-tertiary);
    margin: 0;
    margin-top: auto;
  }

  .related__pl-flag {
    color: var(--accent);
  }
</style>
