---
import { getCollection } from 'astro:content';
import Page from '../../layouts/Page.astro';
import { TAG_LABELS, TAG_DESCRIPTIONS } from '../../utils/tags';
import { url } from '../../utils/url';

const allCases = await getCollection('cases');

// Count tag frequencies
const tagCounts: Record<string, number> = {};
allCases.forEach((c) => {
  (c.data.tags ?? []).forEach((t) => {
    tagCounts[t] = (tagCounts[t] ?? 0) + 1;
  });
});

const sortedTags = Object.entries(tagCounts)
  .map(([tag, count]) => ({
    id: tag,
    label: TAG_LABELS[tag] ?? tag,
    description: TAG_DESCRIPTIONS[tag],
    count,
  }))
  .sort((a, b) => b.count - a.count);
---

<Page
  title="Tagi"
  description="Indeks tagów — mechanizmy, podmioty, konteksty prawne. 33 sprawy ułożone w siatkę tematyczną."
>
  <section class="tags-index">
    <div class="container">
      <header class="tags-index__header">
        <p class="meta" style="color: var(--text-tertiary)">Indeks</p>
        <h1>Tagi</h1>
        <p class="tags-index__lede">
          Każda sprawa ma 3–8 tagów opisujących jej mechanizm, podmiot dotknięty,
          kontekst prawny lub typ wydarzenia. Kliknij tag, żeby zobaczyć wszystkie
          powiązane sprawy.
        </p>
      </header>

      <ul class="tags-index__list">
        {sortedTags.map((t) => (
          <li class="tags-index__item">
            <a href={url(`/tagi/${t.id}/`)} class="tags-index__link">
              <div class="tags-index__head">
                <span class="tags-index__label">{t.label}</span>
                <span class="tags-index__count meta">{t.count}</span>
              </div>
              {t.description && <p class="tags-index__desc">{t.description}</p>}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Page>

<style lang="scss">
  .tags-index {
    padding-block: var(--space-8) var(--space-10);
  }

  .tags-index__header {
    max-width: 720px;
    margin-bottom: var(--space-8);
  }

  .tags-index__header h1 {
    font-family: var(--font-serif);
    font-size: 42px;
    line-height: 1.15;
    margin-block: var(--space-2) var(--space-4);
  }

  .tags-index__lede {
    font-size: 17px;
    line-height: 1.55;
    color: var(--text-secondary);
  }

  .tags-index__list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--gap-3);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .tags-index__item {
    margin: 0;
  }

  .tags-index__link {
    display: flex;
    flex-direction: column;
    gap: var(--gap-2);
    padding: var(--gap-5);
    background: var(--bg-card);
    border: 0.5px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    height: 100%;
    transition: border-color var(--transition-fast);

    &:hover {
      border-color: var(--accent);
      .tags-index__label { color: var(--accent); }
    }
  }

  .tags-index__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--gap-3);
  }

  .tags-index__label {
    font-family: var(--font-serif);
    font-size: 18px;
    font-weight: 500;
    color: var(--text-primary);
    transition: color var(--transition-fast);
  }

  .tags-index__count {
    font-size: 12px;
    color: var(--text-tertiary);
    flex-shrink: 0;
  }

  .tags-index__desc {
    font-size: 13px;
    line-height: 1.5;
    color: var(--text-secondary);
    margin: 0;
  }
</style>
