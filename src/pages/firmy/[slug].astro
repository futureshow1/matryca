---
import { getCollection } from 'astro:content';
import Page from '../../layouts/Page.astro';
import CaseCard from '../../components/case/CaseCard.astro';
import { COMPANIES, companyToSlug } from '../../utils/companies';
import { formatBillions } from '../../utils/format';
import { url } from '../../utils/url';

export async function getStaticPaths() {
  const allCases = await getCollection('cases');

  return Object.values(COMPANIES).map((info) => {
    const cases = allCases
      .filter((c) => (c.data.companies || []).some((n) => companyToSlug(n) === info.slug))
      .sort((a, b) => b.data.year_revealed - a.data.year_revealed);

    const finesEUR = cases.reduce(
      (s, c) => s + c.data.fines.filter((f) => f.currency === 'EUR').reduce((a, f) => a + f.amount, 0),
      0
    );
    const finesUSD = cases.reduce(
      (s, c) => s + c.data.fines.filter((f) => f.currency === 'USD').reduce((a, f) => a + f.amount, 0),
      0
    );

    return {
      params: { slug: info.slug },
      props: { info, cases, finesEUR, finesUSD },
    };
  });
}

const { info, cases, finesEUR, finesUSD } = Astro.props;
---

<Page
  title={`${info.label} — firma`}
  description={info.description}
>
  <section class="firm-page">
    <div class="container">
      <nav class="firm-page__crumb" aria-label="Breadcrumb">
        <a href={url('/firmy/')}>Firmy</a>
        <span aria-hidden="true">/</span>
        <span>{info.label}</span>
      </nav>

      <header class="firm-page__header">
        <p class="meta" style="color: var(--text-tertiary)">Firma</p>
        <h1 class="firm-page__title">{info.label}</h1>
        <p class="firm-page__lede">{info.description}</p>

        <div class="firm-page__stats">
          <div class="firm-page__stat">
            <span class="firm-page__stat-value">{cases.length}</span>
            <span class="firm-page__stat-label meta">
              {cases.length === 1 ? 'sprawa w bazie' : cases.length < 5 ? 'sprawy w bazie' : 'spraw w bazie'}
            </span>
          </div>
          {finesEUR > 0 && (
            <div class="firm-page__stat">
              <span class="firm-page__stat-value">{formatBillions(finesEUR)} €</span>
              <span class="firm-page__stat-label meta">kary w EUR łącznie</span>
            </div>
          )}
          {finesUSD > 0 && (
            <div class="firm-page__stat">
              <span class="firm-page__stat-value">{formatBillions(finesUSD)} $</span>
              <span class="firm-page__stat-label meta">w USD łącznie (wszystkie rodzaje)</span>
            </div>
          )}
        </div>
      </header>

      <div class="firm-page__grid">
        {cases.map((c) => (
          <CaseCard
            id={c.data.id}
            slug={c.data.slug}
            group={c.data.group}
            title={c.data.title}
            subtitle={c.data.subtitle}
            companies={c.data.companies}
            year_revealed={c.data.year_revealed}
            status={c.data.status}
            fines={c.data.fines}
            jurisdictions={c.data.jurisdictions}
            tags={c.data.tags}
            priority={c.data.priority}
            hasExplainer={!!c.data.explainer}
          />
        ))}
      </div>
    </div>
  </section>
</Page>

<style lang="scss">
  .firm-page {
    padding-block: var(--space-8) var(--space-10);
  }

  .firm-page__crumb {
    display: flex;
    gap: var(--gap-2);
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-tertiary);
    margin-bottom: var(--space-6);

    a {
      color: var(--text-secondary);
      text-decoration: none;
      &:hover { color: var(--accent); }
    }
  }

  .firm-page__header {
    max-width: 820px;
    margin-bottom: var(--space-8);
  }

  .firm-page__title {
    font-family: var(--font-serif);
    font-size: 48px;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-block: var(--space-2) var(--space-4);
  }

  .firm-page__lede {
    font-size: 17px;
    line-height: 1.55;
    color: var(--text-secondary);
    margin-bottom: var(--space-6);
  }

  .firm-page__stats {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6);
    padding-top: var(--space-4);
    border-top: 0.5px solid var(--border);
  }

  .firm-page__stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .firm-page__stat-value {
    font-family: var(--font-serif);
    font-size: 28px;
    font-weight: 500;
    color: var(--accent);
    letter-spacing: -0.02em;
  }

  .firm-page__stat-label {
    font-size: 11px;
    color: var(--text-tertiary);
  }

  .firm-page__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--gap-3);
  }
</style>
