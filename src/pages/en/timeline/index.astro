---
import PageEn from '../../../layouts/PageEn.astro';
import ScrollTimeline from '../../../components/timeline/ScrollTimeline';
import { TIMELINE_SCENES as TIMELINE_SCENES_EN } from '../../../data/timeline-scenes-en';
---

<PageEn
  title="Timeline — Big Tech Files"
  description="Sixteen narrative scenes from 2007 to 2025 — one pattern. A scrollytelling history of Big Tech privacy and ethics cases."
>
  <section class="kiedy">
    <div class="container">
      <header class="kiedy__header">
        <p class="meta" style="color: var(--text-tertiary)">Door 02 — narrative version</p>
        <h1>When</h1>
        <p class="kiedy__lede">
          From Facebook Beacon in 2007, when users first publicly protested
          being made subjects of their own shopping, to localhost in 2025,
          when Meta and Yandex apps were shown to bypass every browser
          safeguard to keep tracking in incognito mode.
        </p>
        <p class="kiedy__note">
          Sixteen scenes — year by year, case by case. Scroll down, each
          scene stops so you can read it. ~12,000 words of narrative.
        </p>
      </header>

      <ScrollTimeline
        client:load
        scenes={TIMELINE_SCENES_EN}
        labels={{ casesLabel: 'Cases:', sceneLabel: 'Scene', casesHrefPrefix: '/en/cases/' }}
      />

      <footer class="kiedy__footer">
        <p class="meta">
          Version 2 — sixteen scenes, ~700 words each. We continue to
          deepen individual years.
        </p>
      </footer>
    </div>
  </section>
</PageEn>

<style lang="scss">
  .kiedy {
    padding-block: var(--space-8) 0;
  }

  .kiedy__header {
    max-width: 760px;
    margin-bottom: var(--space-10);
  }

  .kiedy__header h1 {
    font-family: var(--font-serif);
    font-size: 52px;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-block: var(--space-2) var(--space-4);
  }

  .kiedy__lede {
    font-size: 17px;
    line-height: 1.6;
    color: var(--text-secondary);
    margin-bottom: var(--space-3);
  }

  .kiedy__note {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-tertiary);
    margin: 0;
  }

  .kiedy__footer {
    margin-top: var(--space-16);
    padding: var(--space-6) 0;
    border-top: 0.5px solid var(--border);
    text-align: center;
  }

  .kiedy__footer .meta {
    color: var(--text-tertiary);
  }

  @media (max-width: 900px) {
    .kiedy__header h1 {
      font-size: 36px;
    }
  }
</style>
