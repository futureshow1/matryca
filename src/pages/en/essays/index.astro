---
import PageEn from '../../../layouts/PageEn.astro';
import { url } from '../../../utils/url';

const essays = [
  {
    slug: 'from-authors',
    title: 'From the authors',
    length: '~2,400 words',
    teaser: 'Why a reference portal, why in Polish first, why now. A database that documents privacy violations cannot itself violate privacy. The design choices behind Matryca — no analytics, no cookies, no external trackers — are part of the method, not a decoration.',
  },
  {
    slug: 'from-a-lawyer',
    title: 'From a lawyer',
    length: '~3,100 words',
    teaser: 'GDPR is not a paper. The legal architecture behind enforcement — why the Irish DPC is the choke point, why Schrems I and Schrems II are structurally different, how "dark patterns" became a recognised legal category. A practitioner view of what the case-base shows about European administrative law.',
  },
  {
    slug: 'from-an-organization',
    title: 'From an organization',
    length: '~2,800 words',
    teaser: 'Written from the perspective of the Panoptykon Foundation — Poland\'s principal civil-liberties organisation focused on digital rights. Why individual cases require organisational response. How NOYB, EDRi, EFF, Panoptykon split the enforcement burden. What a single citizen realistically can and cannot do.',
  },
  {
    slug: 'from-a-citizen',
    title: 'From a citizen',
    length: '~2,200 words',
    teaser: 'From the user side. How to read a case card without becoming despairing or cynical. What concretely can you change in your week. What is worth changing and what is performative. Written as a companion to the "conclusions for citizens" section of each case card.',
  },
];
---

<PageEn
  title="Essays — Big Tech Files"
  description="Four editorial essays framing the portal: from the authors, from a lawyer, from an organization, from a citizen."
>
  <article class="editorial">
    <div class="container">
      <header class="editorial__header">
        <p class="meta" style="color: var(--text-tertiary)">Editorial framing — four essays</p>
        <h1>Essays</h1>
        <p class="editorial__lede">
          The case cards are documentary. The essays are interpretive. Four
          voices — the project authors, a lawyer, an organization working on
          digital rights, and a private citizen — each read the same 33-case
          database from a different angle.
        </p>
      </header>

      <ul class="essay-list">
        {essays.map((e) => (
          <li class="essay-list__item">
            <a href={url(`/en/essays/${e.slug}/`)} class="essay-list__link">
              <p class="essay-list__length">{e.length}</p>
              <h2 class="essay-list__title">{e.title}</h2>
              <p class="essay-list__teaser">{e.teaser}</p>
              <p class="essay-list__action meta">Read →</p>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </article>
</PageEn>

<style lang="scss">
  .editorial {
    padding-block: var(--space-8);
  }

  .editorial__header {
    max-width: 760px;
    margin-bottom: var(--space-10);
  }

  .editorial__header h1 {
    font-family: var(--font-serif);
    font-size: 42px;
    line-height: 1.15;
    margin-block: var(--space-2) var(--space-4);
  }

  .editorial__lede {
    font-size: 17px;
    line-height: 1.55;
    color: var(--text-secondary);
    margin: 0;
  }

  .essay-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .essay-list__item {
    max-width: 820px;
    border-top: 0.5px solid var(--border);

    &:last-child {
      border-bottom: 0.5px solid var(--border);
    }
  }

  .essay-list__link {
    display: block;
    padding: var(--space-6) 0;
    text-decoration: none;
    color: inherit;
    transition: color var(--transition-fast);

    &:hover {
      .essay-list__title { color: var(--accent); }
      .essay-list__action { color: var(--accent); }
    }
  }

  .essay-list__length {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-tertiary);
    letter-spacing: 0.06em;
    margin: 0 0 var(--space-2);
    text-transform: uppercase;
  }

  .essay-list__title {
    font-family: var(--font-serif);
    font-size: 28px;
    font-weight: 500;
    line-height: 1.2;
    margin: 0 0 var(--space-3);
    transition: color var(--transition-fast);
  }

  .essay-list__teaser {
    font-size: 16px;
    line-height: 1.65;
    color: var(--text-primary);
    margin: 0 0 var(--space-3);
    max-width: 720px;
  }

  .essay-list__action {
    font-size: 11px;
    color: var(--text-tertiary);
    margin: 0;
    transition: color var(--transition-fast);
  }
</style>
