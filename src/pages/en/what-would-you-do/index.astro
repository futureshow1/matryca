---
import PageEn from '../../../layouts/PageEn.astro';
import DecisionGameEn from '../../../components/game/DecisionGameEn';
---

<PageEn
  title="What would you do? — Big Tech Files"
  description="Five real decisions from the history of Big Tech — Frances Haugen, Max Schrems, Johannes Caspar, Christopher Wylie, the Dragonfly engineer. What would you have done?"
>
  <section class="game">
    <div class="container">
      <header class="game__header">
        <p class="meta" style="color: var(--text-tertiary)">Decision game — five scenarios</p>
        <h1 class="game__title">What would you do?</h1>
        <p class="game__lede">
          History tends to turn on specific decisions by specific people in
          specific rooms. Here are five real ones. Each is described from the
          point of view of the person in the room — before they knew how it
          would end.
        </p>
        <p class="game__note">
          After each choice you will see: the consequence of your choice —
          and what actually happened in history. Your answers are not saved.
        </p>
      </header>

      <DecisionGameEn client:load />
    </div>
  </section>
</PageEn>

<style lang="scss">
  .game {
    padding-block: var(--space-8) var(--space-12);
  }

  .game__header {
    max-width: 760px;
    margin-bottom: var(--space-8);
  }

  .game__title {
    font-family: var(--font-serif);
    font-size: 42px;
    line-height: 1.15;
    margin-block: var(--space-2) var(--space-4);
  }

  .game__lede {
    font-size: 17px;
    line-height: 1.6;
    color: var(--text-secondary);
    margin-bottom: var(--space-3);
  }

  .game__note {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-tertiary);
    margin: 0;
    padding-top: var(--space-2);
    border-top: 0.5px solid var(--border);
  }
</style>
