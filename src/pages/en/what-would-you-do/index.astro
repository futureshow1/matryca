---
import PageEn from '../../../layouts/PageEn.astro';
import { url } from '../../../utils/url';

const scenarios = [
  {
    id: 'haugen',
    title: 'Frances Haugen\'s decision',
    year: '2021',
    setup: 'You work as a product manager in Meta\'s Civic Integrity team. You have seen internal research — Instagram harms teen girls, the algorithm promotes anger, XCheck protects 5.8 million VIP accounts from moderation. Management reads your reports and changes nothing. Your contract says disclosure is a crime. What do you do?',
  },
  {
    id: 'schrems',
    title: 'Max Schrems\' question',
    year: '2011',
    setup: 'You are a 23-year-old law student in Vienna on exchange in Silicon Valley. You ask Facebook — under Irish law — what data they have on you. They send you 1,200 pages: everything, including messages you deleted, friends you blocked, photos you untagged. You can let it go. Or you can do something. What?',
  },
  {
    id: 'caspar',
    title: 'Johannes Caspar\'s audit',
    year: '2010',
    setup: 'You are Commissioner for Data Protection in Hamburg. Budget: €3M. Staff: 18. Google Street View cars are driving through your city. You notice an antenna on the roof and ask Google what it does. They say "Wi-Fi names only". You could accept that. Or you could push. And push again.',
  },
  {
    id: 'wylie',
    title: 'Christopher Wylie\'s disclosure',
    year: '2018',
    setup: 'You are 28, you worked at Cambridge Analytica as research director, you saw 87 million Facebook profiles harvested for psychographic targeting in Trump 2016 and Brexit. The firm\'s NDAs promise legal war. Journalists — Carole Cadwalladr, The Observer — are asking for a source. What do you tell them?',
  },
  {
    id: 'dragonfly',
    title: 'The Dragonfly engineer',
    year: '2018',
    setup: 'You are a Google engineer on Project Dragonfly. The project is secret: a censored search engine for China. It will filter "human rights", "Tiananmen", "Dalai Lama". Your paycheck pays your mortgage. Your NDA is strict. But The Intercept is calling. And 1,400 of your colleagues have already signed an internal letter of protest.',
  },
];
---

<PageEn
  title="What would you do? — Big Tech Files"
  description="Five real decisions from the history of Big Tech — Frances Haugen, Max Schrems, Johannes Caspar, Christopher Wylie, the Dragonfly engineer. What would you have done?"
>
  <article class="editorial">
    <div class="container">
      <header class="editorial__header">
        <p class="meta" style="color: var(--text-tertiary)">Decision game — five scenarios</p>
        <h1>What would you do?</h1>
        <p class="editorial__lede">
          History tends to turn on specific decisions by specific people in
          specific rooms. Here are five real ones. Each is described from the
          point of view of the person in the room — before they knew how
          it would end.
        </p>
        <p class="editorial__note">
          Interactive game is currently available in the Polish edition only.
          English scenarios below are summaries. The full interactive version —
          with four choices, consequence text, and scoring — is planned for
          Phase 4.
        </p>
      </header>

      <ol class="scenario-list">
        {scenarios.map((s, i) => (
          <li class="scenario-list__item">
            <p class="scenario-list__num">Scenario {i + 1} · {s.year}</p>
            <h2 class="scenario-list__title">{s.title}</h2>
            <p class="scenario-list__setup">{s.setup}</p>
          </li>
        ))}
      </ol>

      <p class="editorial__note" style="margin-top: var(--space-10);">
        Try the full interactive version — <a href={url('/gra/')}>Polish decision game</a>.
        The UI is in Polish but scenarios are based on the same five moments described above.
      </p>
    </div>
  </article>
</PageEn>

<style lang="scss">
  .editorial {
    padding-block: var(--space-8);
  }

  .editorial__header {
    max-width: 760px;
    margin-bottom: var(--space-10);
  }

  .editorial__header h1 {
    font-family: var(--font-serif);
    font-size: 42px;
    line-height: 1.15;
    margin-block: var(--space-2) var(--space-4);
  }

  .editorial__lede {
    font-size: 17px;
    line-height: 1.55;
    color: var(--text-secondary);
    margin-bottom: var(--space-3);
  }

  .editorial__note {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-tertiary);
    padding-top: var(--space-2);
    border-top: 0.5px solid var(--border);
    margin: 0;

    a {
      color: var(--accent);
      text-decoration: none;
      border-bottom: 1px solid transparent;
      transition: border-color var(--transition-fast);

      &:hover { border-bottom-color: var(--accent); }
    }
  }

  .scenario-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .scenario-list__item {
    padding: var(--space-6) 0;
    border-top: 0.5px solid var(--border);
    max-width: 760px;

    &:last-child {
      border-bottom: 0.5px solid var(--border);
    }
  }

  .scenario-list__num {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.08em;
    margin: 0 0 var(--space-2);
    text-transform: uppercase;
  }

  .scenario-list__title {
    font-family: var(--font-serif);
    font-size: 26px;
    font-weight: 500;
    line-height: 1.3;
    margin: 0 0 var(--space-3);
  }

  .scenario-list__setup {
    font-size: 16px;
    line-height: 1.65;
    color: var(--text-primary);
    margin: 0;
  }
</style>
