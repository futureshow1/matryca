---
import PageEn from '../../../layouts/PageEn.astro';
import { PEOPLE, ROLE_LABELS_EN } from '../../../data/people-en';
import { url } from '../../../utils/url';
---

<PageEn
  title="Who revealed it — Big Tech Files"
  description="Twelve whistleblowers, journalists, researchers and regulators who forced the stories into the public record."
>
  <article class="people">
    <div class="container">
      <header class="people__header">
        <p class="meta" style="color: var(--text-tertiary)">Gallery — twelve profiles</p>
        <h1 class="people__title">Who revealed it</h1>
        <p class="people__lede">
          None of the 33 cases documented in Big Tech Files came to light by
          itself. Each was forced into the public record by specific people
          doing specific work at specific moments. This gallery is a minimum
          map of that labour.
        </p>
      </header>

      <ul class="people__list">
        {PEOPLE.map((p) => (
          <li class="person">
            <div class="person__head">
              <div class="person__avatar" aria-hidden="true">{p.portrait_initials}</div>
              <div>
                <h2 class="person__name">{p.name}</h2>
                <p class="person__meta meta">
                  {ROLE_LABELS_EN[p.role]}
                  {p.affiliation && <span> · {p.affiliation}</span>}
                  {' · '}{p.years}
                </p>
              </div>
            </div>
            <p class="person__short">{p.bio_short}</p>
            <div class="person__bio" set:html={p.bio_long.split('\n\n').map((para) => `<p>${para}</p>`).join('')}></div>
            {p.caseIds.length > 0 && (
              <p class="person__cases meta">
                Cases: {p.caseIds.map((cid, i) => (
                  <>
                    <a href={url(`/en/cases/`)}>{cid}</a>{i < p.caseIds.length - 1 && <span> · </span>}
                  </>
                ))}
              </p>
            )}
          </li>
        ))}
      </ul>
    </div>
  </article>
</PageEn>

<style lang="scss">
  .people {
    padding-block: var(--space-8);
  }

  .people__header {
    max-width: 760px;
    margin-bottom: var(--space-10);
  }

  .people__title {
    font-family: var(--font-serif);
    font-size: 42px;
    line-height: 1.15;
    margin-block: var(--space-2) var(--space-4);
  }

  .people__lede {
    font-size: 17px;
    line-height: 1.55;
    color: var(--text-secondary);
    margin: 0;
  }

  .people__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .person {
    padding: var(--space-6) 0;
    border-top: 0.5px solid var(--border);
    max-width: 760px;

    &:last-child {
      border-bottom: 0.5px solid var(--border);
    }
  }

  .person__head {
    display: flex;
    gap: var(--gap-4);
    align-items: center;
    margin-bottom: var(--space-3);
  }

  .person__avatar {
    width: 48px;
    height: 48px;
    background: var(--bg-secondary);
    border: 0.5px solid var(--border);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--accent);
    letter-spacing: 0.04em;
    flex-shrink: 0;
  }

  .person__name {
    font-family: var(--font-serif);
    font-size: 24px;
    font-weight: 500;
    margin: 0 0 4px;
  }

  .person__meta {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-tertiary);
    margin: 0;
  }

  .person__short {
    font-family: var(--font-serif);
    font-size: 18px;
    font-style: italic;
    line-height: 1.4;
    color: var(--text-primary);
    margin: 0 0 var(--space-3);
  }

  .person__bio {
    font-size: 15px;
    line-height: 1.65;
    color: var(--text-primary);

    p {
      margin: 0 0 var(--space-3);

      &:last-child {
        margin-bottom: 0;
      }
    }
  }

  .person__cases {
    margin-top: var(--space-3);
    padding-top: var(--space-3);
    border-top: 0.5px solid var(--border);
    font-size: 11px;
    color: var(--text-tertiary);

    a {
      color: var(--accent);
      text-decoration: none;
      border-bottom: 1px solid transparent;
      transition: border-color var(--transition-fast);

      &:hover { border-bottom-color: var(--accent); }
    }
  }
</style>
