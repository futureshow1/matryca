---
import PageEn from '../../../layouts/PageEn.astro';
import QuizEn from '../../../components/quiz/QuizEn';
---

<PageEn
  title="How much they know — Big Tech Files"
  description="Fifteen quick questions that map what Big Tech actually knows about you. Each linked to a documented case."
>
  <section class="quiz">
    <div class="container">
      <header class="quiz__header">
        <p class="meta" style="color: var(--text-tertiary)">Diagnostic questionnaire — 15 questions</p>
        <h1 class="quiz__title">How much they know</h1>
        <p class="quiz__lede">
          Fifteen quick questions about your digital habits. Each question is
          linked to at least one documented case in the database. Answer
          honestly — no-one is watching (this portal collects no data).
        </p>
      </header>

      <QuizEn client:load />
    </div>
  </section>
</PageEn>

<style lang="scss">
  .quiz {
    padding-block: var(--space-8) var(--space-12);
  }

  .quiz__header {
    max-width: 760px;
    margin-bottom: var(--space-8);
  }

  .quiz__title {
    font-family: var(--font-serif);
    font-size: 42px;
    line-height: 1.15;
    margin-block: var(--space-2) var(--space-4);
  }

  .quiz__lede {
    font-size: 17px;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0;
  }
</style>
